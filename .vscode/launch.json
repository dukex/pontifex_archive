{
  "version": "0.2.0",
  "configurations": [ 
    {
      "type": "debugpy",
      "request": "launch",
      "module": "uv",
      "python": "${workspaceFolder}/generator/.venv/bin/python",
      "name": "generate",
      "cwd": "${workspaceFolder}/generator",
      "args": [
        "run",
        "generator"
      ],
      "console": "integratedTerminal"
    },
    {
      "type": "debugpy",
      "request": "launch",
      "module": "uv",
      "python": "${workspaceFolder}/generator/.venv/bin/python",
      "name": "book-volumes-generator",
      "cwd": "${workspaceFolder}/generator",
      "args": [
        "run",
        "book-volumes-generator"
      ],
      "env": {
        "DYLD_LIBRARY_PATH": "/opt/homebrew/lib"
      },
      "console": "integratedTerminal"
    },
    {
      "name": "run",
      "type": "dart",
      "request": "launch",
      "cwd": "${workspaceFolder}/app",
      "program": "lib/main.dart"
    },
    {
      "name": "run: chrome",
      "program": "lib/web/main.dart",
      "cwd": "app",
      "deviceId": "chrome",
      "request": "launch",
      "type": "dart"
    },
    {
      "name": "run: linux",
      "program": "lib/main.dart",
      "cwd": "app",
      "deviceId": "linux",
      "request": "launch",
      "type": "dart"
    }
  ]
}